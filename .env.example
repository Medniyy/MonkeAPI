NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Set this to your public Railway/custom domain for canonical URLs.
# BASE_URL=https://api.example.com

INDEX_PATH=./data/index.json
CACHE_DIR=./.cache
CUTOUT_DIR=./data/cutouts

UPSTREAM_TIMEOUT_MS=15000
MAX_IMAGE_BYTES=20971520
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=1 minute

# Comma-separated. Redirects are checked against this allowlist too.
ALLOWED_IMAGE_HOSTS=permagate.io,gateway.irys.xyz,datasprite-cdn.com,arweave.net,cdn.helius-rpc.com,ipfs.io,nftstorage.link

# Optional background-removal service. It receives the source image bytes
# in a POST and must return a transparent image/png.
# CUTOUT_SERVICE_URL=https://your-rembg-service.example/remove
# CUTOUT_SERVICE_TOKEN=
